# Connect to Supabase via connection pooling
# For local database (SQLite)
DATABASE_URL="sqlite:///./testlink.db"
# For supabase or any other DB, replace the link

# Auth — generate a strong random string: openssl rand -hex 32
SECRET_KEY="your-secret-key-here"
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AI Provider — swap these three lines to change models
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.1-8b-instant"
AI_API_KEY="your-api-key"

# App
APP_NAME="TestLink Rebuild"
ENVIRONMENT="development"
FRONTEND_URL="http://localhost:3000"
